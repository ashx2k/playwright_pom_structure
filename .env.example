# Base URL for tests
BASE_URL=https://playwright.dev

# Global viewport used by playwright.config.ts
VIEWPORT_WIDTH=1366
VIEWPORT_HEIGHT=768

# CI notification target (set this as a GitHub secret: REPORT_EMAIL_TO_SELECTED)
# Example: qa-owner@company.com
# REPORT_EMAIL_TO_SELECTED=

# Optional Slack secret (only needed if you enable the commented Slack step)
# SLACK_WEBHOOK_URL=
