# Base URL for tests
BASE_URL=https://playwright.dev

# Global viewport used by playwright.config.js
VIEWPORT_WIDTH=1366
VIEWPORT_HEIGHT=768

# Optional local URL root used by scripts/post-report-workflow.sh
# If empty, local flow prints file://... URL
# LOCAL_REPORT_BASE_URL=http://localhost:8080/reports

# Optional: set to true only when SMTP values are provided
# SEND_EMAIL=false

# CI notification target (set this as a GitHub secret: REPORT_EMAIL_TO_SELECTED)
# Example: qa-owner@company.com
# REPORT_EMAIL_TO_SELECTED=

# SMTP configuration (needed for email sending in local post-report flow)
# SMTP_SERVER=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# REPORT_EMAIL_FROM=

# Optional Slack secret (only needed if you enable the commented Slack step)
# SLACK_WEBHOOK_URL=
